<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/tile_bg_active" />
            <corners android:radius="@dimen/corner_radius_tile" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/tile_bg_inactive" />
            <corners android:radius="@dimen/corner_radius_tile" />
        </shape>
    </item>
</selector>
